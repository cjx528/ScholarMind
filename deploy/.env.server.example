# Copy this file to .env.server on the server, then fill real values.
# Do not commit .env.server.

SCHOLARMIND_IMAGE=ghcr.io/cjx528/scholarmind:latest

# Direct-IP deployment uses this host port.
# If the server has no other web service, keep 80 and open http://SERVER_IP/.
SCHOLARMIND_HTTP_PORT=80

# Domain deployment with Caddy uses this domain and gets HTTPS automatically.
# Example: scholarmind.example.com
SCHOLARMIND_DOMAIN=

# Browser origin for CORS.
# For direct IP: http://SERVER_IP
# For domain: https://scholarmind.example.com
PUBLIC_ORIGIN=*

APP_ENV=production
APP_NAME=ScholarMind API
LLM_PROVIDER=zhipu

ZHIPU_API_KEY=
EMBEDDING_API_KEY=
OPENALEX_EMAIL=

LLM_MODEL_SKIM=glm-4.7-flash
LLM_MODEL_DEEP=glm-5.1
LLM_MODEL_VISION=glm-4.6v
LLM_MODEL_FALLBACK=glm-4.7-flash
EMBEDDING_MODEL=embedding-3
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_DIMENSIONS=1024

# Required for a public deployment. Share this password only with allowed users.
AUTH_PASSWORD=
AUTH_SECRET_KEY=change-this-to-a-long-random-string

COST_GUARD_ENABLED=true
PER_CALL_BUDGET_USD=0.05
DAILY_BUDGET_USD=2.0
SKIM_SCORE_THRESHOLD=0.65

IDLE_PROCESSOR_ENABLED=true
IDLE_BATCH_SIZE=5
IDLE_CHECK_INTERVAL=60
IDLE_CPU_THRESHOLD=30.0
IDLE_MEMORY_THRESHOLD=70.0
IDLE_REQUEST_THRESHOLD=5

WORKER_RETRY_MAX=3
WORKER_RETRY_BASE_DELAY=5.0
