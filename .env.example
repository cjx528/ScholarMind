# ==========================================
# ScholarMind environment example
# ==========================================
#
# Local development:
#   Copy-Item .env.example .env
#
# Docker deployment:
#   Copy-Item .env.example .env
#
# At least one LLM API key is required for AI features.
# Do not commit a real .env file.

# ------------------------------------------
# Basic app config
# ------------------------------------------
APP_ENV=production
APP_NAME=ScholarMind API
API_HOST=0.0.0.0
API_PORT=8000

# Local development: sqlite:///./data/scholarmind.db
# Docker deployment: sqlite:////app/data/scholarmind.db
DATABASE_URL=sqlite:///./data/scholarmind.db

PDF_STORAGE_ROOT=./data/papers
BRIEF_OUTPUT_ROOT=./data/briefs

# Local development can use *.
# Docker deployment usually uses http://localhost:3002,http://127.0.0.1:3002
CORS_ALLOW_ORIGINS=*

# ------------------------------------------
# LLM provider config
# ------------------------------------------
# Supported provider names: xiaomi / zhipu / openai / anthropic
LLM_PROVIDER=zhipu

# ZhipuAI, used as the course demo default.
ZHIPU_API_KEY=

# Optional providers.
XIAOMI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# External paper APIs.
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_EMAIL=

# Model defaults for the course demo.
LLM_MODEL_SKIM=glm-4.7-flash
LLM_MODEL_DEEP=glm-5.1
LLM_MODEL_VISION=glm-4.6v
LLM_MODEL_FALLBACK=glm-4.7-flash

# Optional local Codex CLI backend for agent/analysis extensions.
SCHOLARMIND_CODEX_CLI=
SCHOLARMIND_CODEX_MODEL=gpt-5.5

# Embedding defaults for Zhipu.
EMBEDDING_MODEL=embedding-3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_DIMENSIONS=1024

# ------------------------------------------
# Cost guard
# ------------------------------------------
COST_GUARD_ENABLED=true
PER_CALL_BUDGET_USD=0.05
DAILY_BUDGET_USD=2.0
SKIM_SCORE_THRESHOLD=0.65

# ------------------------------------------
# Auth
# ------------------------------------------
# Empty AUTH_PASSWORD disables login protection.
AUTH_PASSWORD=
AUTH_SECRET_KEY=scholarmind-secret-key-change-in-production

# ------------------------------------------
# SMTP notification config
# ------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_DEFAULT_TO=

# ------------------------------------------
# Scheduler config, UTC time
# ------------------------------------------
# Daily brief: UTC 04:00 = Beijing 12:00
DAILY_CRON=0 4 * * *

# Weekly graph: UTC Sunday 22:00 = Beijing Monday 06:00
WEEKLY_CRON=0 22 * * 0

# Default topic fetch hour in UTC, 0-23.
DEFAULT_TOPIC_TIME_UTC=2

# Max deep reads per topic per run.
DEFAULT_MAX_DEEP_READS=2

# ------------------------------------------
# Idle processor
# ------------------------------------------
IDLE_PROCESSOR_ENABLED=true
IDLE_BATCH_SIZE=5
IDLE_CHECK_INTERVAL=60
IDLE_CPU_THRESHOLD=30.0
IDLE_MEMORY_THRESHOLD=70.0
IDLE_REQUEST_THRESHOLD=5

# ------------------------------------------
# Worker retry
# ------------------------------------------
WORKER_RETRY_MAX=3
WORKER_RETRY_BASE_DELAY=5.0
